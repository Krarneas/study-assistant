# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment variable template for Smart PDF Study Assistant
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your OpenAI API key below.
#   3. Never commit your .env file — it contains secrets.
#
# All values shown here are the application defaults.
# Only OPENAI_API_KEY MUST be changed; everything else is optional.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Model selection ───────────────────────────────────────────────────────────
# Chat model — gpt-4o-mini is cheap and capable; upgrade to gpt-4o for better answers
CHAT_MODEL=gpt-4o-mini

# Embedding model — text-embedding-3-small is fast and accurate
EMBEDDING_MODEL=text-embedding-3-small

# ── PDF chunking (Context Engineering) ───────────────────────────────────────
# Number of words per chunk (500 words ≈ 375 tokens)
CHUNK_SIZE=500

# Words shared between adjacent chunks to avoid cutting sentences
CHUNK_OVERLAP=50

# ── Retrieval (Context Engineering) ──────────────────────────────────────────
# Chunks retrieved on the first loop iteration
TOP_K_INITIAL=3

# Additional chunks retrieved on each subsequent loop iteration
TOP_K_EXTRA=3

# ── Loop Engineering ──────────────────────────────────────────────────────────
# Maximum number of retrieve → generate → evaluate cycles
MAX_LOOP_ITERATIONS=3

# ── Conversation memory (Context Engineering) ────────────────────────────────
# How many previous question-answer pairs to include in each prompt
MAX_HISTORY_EXCHANGES=3

# ── LLM generation ────────────────────────────────────────────────────────────
# Lower temperature = more factual / deterministic answers
TEMPERATURE=0.2

# Maximum tokens in the LLM's reply
MAX_TOKENS=1024

# ── Retry / Harness Engineering ───────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2.0

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=lecture_notes

# ── FastAPI (optional server mode) ───────────────────────────────────────────
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
